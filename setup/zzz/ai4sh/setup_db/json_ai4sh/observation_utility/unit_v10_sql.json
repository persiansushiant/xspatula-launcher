{
  "process": [
    {
      "process_id": "create_table",
      "overwrite": false,
      "delete": false,
      "parameters": {
        "schema": "observation_utility",
        "table": "unit",
        "command": [
          "id SERIAL",
          "name TEXT",
          "alias TEXT UNIQUE",
          "display_name TEXT",
          "abstract TEXT",
          "system TEXT",
          "UNIQUE (name, system)",
          "PRIMARY KEY (id)"
        ]
      }
    }
  ]
}
