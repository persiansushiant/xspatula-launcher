          "abstract TEXT",
          "sampling_date DATE",
          "time_series_id INTEGER DEFAULT 0",
          "timestamp TIMESTAMP DEFAULT CURRENT_TIMESTAMP(1)",
          "UNIQUE (sampling_log_id, name)",
          "PRIMARY KEY (id)"
        ]
      }
    },
