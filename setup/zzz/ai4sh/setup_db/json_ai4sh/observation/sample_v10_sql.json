      "delete": false,
      "parameters": {
        "schema": "observation",
        "table": "sample",
        "command": [
          "id SERIAL",
          "sampling_log_id INTEGER REFERENCES observation.sampling_log (id)",
          "tag TEXT",
          "name TEXT",
