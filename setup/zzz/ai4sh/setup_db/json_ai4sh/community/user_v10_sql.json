{
  "process": [
    {
      "process_id": "create_table",
      "overwrite": false,
      "delete": false,
      "parameters": {
        "schema": "community",
        "table": "user",
        "command": [
          "id SERIAL",
          "organisation_id INTEGER REFERENCES community.organisation (id)",
          "user_name VARCHAR UNIQUE",
          "password VARCHAR",
          "stratum_code SMALLINT REFERENCES community.user_categories (stratum_code) DEFAULT 0",
          "first_name VARCHAR",
          "middle_name VARCHAR",
          "last_name VARCHAR",
          "email VARCHAR",
          "email_alt VARCHAR",
          "address1 VARCHAR",
          "address2 VARCHAR",
          "postal_address VARCHAR",
          "postal_zip_code VARCHAR",
          "state VARCHAR",
          "territory_id INTEGER REFERENCES utility.territory (id)",
          "telephone VARCHAR",
          "department VARCHAR",
          "section VARCHAR",
          "position VARCHAR",
          "create_timestamp TIMESTAMP DEFAULT CURRENT_TIMESTAMP(1)",
          "last_update_timestamp TIMESTAMP DEFAULT CURRENT_TIMESTAMP(1)",
          "status_code INTEGER DEFAULT 10",
          "PRIMARY KEY (id)"
        ]
      }
    },
    {
      "process_id": "create_table",
      "overwrite": false,
      "delete": false,
      "parameters": {
        "schema": "community",
        "table": "user_media",
        "command": [
          "user_id INTEGER REFERENCES community.user (id)",
          "url VARCHAR",
          "facebook VARCHAR",
          "twitter VARCHAR",
          "snapchat VARCHAR",
          "instagram VARCHAR",
          "lnikedin VARCHAR",
          "PRIMARY KEY (user_id)"
        ]
      }
    },
    {
      "process_id": "create_table",
      "overwrite": false,
      "delete": false,
      "parameters": {
        "schema": "community",
        "table": "user_activity",
        "command": [
          "user_id INTEGER REFERENCES community.user (id)",
          "total_minutes INTEGER DEFAULT 0",
          "last_activity_date DATE DEFAULT CURRENT_DATE",
          "PRIMARY KEY (user_id)"
        ]
      }
    }
  ]
}
