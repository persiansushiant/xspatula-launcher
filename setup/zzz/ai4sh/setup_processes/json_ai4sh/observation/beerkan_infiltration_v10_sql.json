{
  "process": [
    {
      "process": "add_process",
      "overwrite": false,
      "parameters": {
        "root_process": "manage_table_data",
        "process": "manage_beerkan_observation",
        "min_user_stratum": 2,
        "title": "Manage beerkan infiltration observation",
        "label": "Insert, update or delete beerkan field observation data."
      },
      "nodes": [
        {
          "parent": "process",
          "element": "parameters",
          "parameter": [
            {
              "parameter": "sampling_log_id__sampling_log_name",
              "parameter_type": "text",
              "required": true,
              "default_value": "",
              "hint": "The name of the sampling log to which this observation belongs",
              "schema_table": {
                "schema": "observation",
                "table": "sampling_log",
                "write": true
              },
              "permission": {
                "update": false,
                "delete": false
              }
            },
            {
              "parameter": "sample_id__sample_name",
              "parameter_type": "text",
              "required": true,
              "default_value": "",
              "hint": "The name of the sample",
              "schema_table": {
                "schema": "observation",
                "table": "observation",
                "write": true
              },
              "permission": {
                "update": false,
                "delete": false
              }
            },
            {
              "parameter": "provision_id__provision_name",
              "parameter_type": "text",
              "required": false,
              "default_value": "beerkan estimation of soil hydraulic properties",
              "hint": "Default name that should not be changed",
              "schema_table": {
                "schema": "observation",
                "table": "observation",
                "write": true
              },
              "permission": {
                "update": false,
                "delete": false
              }
            },
            {
              "parameter": "observation_log_id__observation_log_name",
              "parameter_type": "text",
              "required": false,
              "default_value": "auto",
              "hint": "Let the observation_log_name be set automatically",
              "schema_table": {
                "schema": "observation",
                "table": "observation",
                "write": true
              },
              "permission": {
                "update": false,
                "delete": false
              },
              "auto_name": {
                "concat": "'%s@beerkan' %(sampling_log_id__sampling_log_name)"
              }
            },
            {
              "parameter": "ring_diameter",
              "parameter_type": "float",
              "required": true,
              "default_value": 8,
              "hint": "The inner ring diameter of the ring (can) used for the infiltration test.",
              "schema_table": {
                "schema": "observation",
                "table": "infiltration_beerkan",
                "write": true
              },
              "permission": {
                "update": true,
                "delete": false
              }
            },
            {
              "parameter": "ring_diameter_unit_id__ring_diameter_unit_name",
              "parameter_type": "text",
              "required": false,
              "default_value": "cm",
              "hint": "The unit in whihc the inner ring diameter is given.",
              "schema_table": {
                "schema": "observation",
                "table": "infiltration_beerkan",
                "write": true
              },
              "permission": {
                "update": true,
                "delete": false
              }
            },
            {
              "parameter": "unit_water_volume",
              "parameter_type": "float",
              "required": true,
              "default_value": 50,
              "hint": "The unit water volume poured into the ring.",
              "schema_table": {
                "schema": "observation",
                "table": "infiltration_beerkan",
                "write": true
              },
              "permission": {
                "update": true,
                "delete": false
              }
            },
            {
              "parameter": "unit_water_volume_unit_id__unit_water_volume_unit_name",
              "parameter_type": "text",
              "required": false,
              "default_value": "ml",
              "hint": "The unit water volume unit.",
              "schema_table": {
                "schema": "observation",
                "table": "infiltration_beerkan",
                "write": true
              },
              "permission": {
                "update": true,
                "delete": false
              }
            },
            {
              "parameter": "initial_soil_moisture_volume_percent",
              "parameter_type": "smallint",
              "required": false,
              "default_value": 0,
              "hint": "The initial volumetric soil moisture content.",
              "schema_table": {
                "schema": "observation",
                "table": "infiltration_beerkan",
                "write": true
              },
              "permission": {
                "update": true,
                "delete": false
              }
            },
            {
              "parameter": "final_soil_moisture_volume_percent",
              "parameter_type": "smallint",
              "required": false,
              "default_value": 0,
              "hint": "The final volumetric soil moisture content.",
              "schema_table": {
                "schema": "observation",
                "table": "infiltration_beerkan",
                "write": true
              },
              "permission": {
                "update": true,
                "delete": false
              }
            },
            {
              "parameter": "subsample",
              "parameter_type": "text",
              "required": false,
              "default_value": "a",
              "hint": "Subsample name (only accpets values in a, b, c, ... h), applicable if the same sample is divided and observed more than once in the same log",
              "schema_table": {
                "schema": "observation",
                "table": "observation",
                "write": true
              },
              "permission": {
                "update": false,
                "delete": false
              },
              "set_value": [
                {
                  "value": "a",
                  "label": "A"
                },
                {
                  "value": "b",
                  "label": "B"
                },
                {
                  "value": "c",
                  "label": "C"
                },
                {
                  "value": "d",
                  "label": "D"
                },
                {
                  "value": "e",
                  "label": "E"
                },
                {
                  "value": "f",
                  "label": "F"
                },
                {
                  "value": "g",
                  "label": "G"
                },
                {
                  "value": "h",
                  "label": "H"
                }
              ]
            },
            {
              "parameter": "abstract",
              "parameter_type": "text",
              "required": false,
              "default_value": "",
              "hint": "Any notation related to the observation",
              "schema_table": {
                "schema": "observation",
                "table": "observation",
                "write": true
              },
              "permission": {
                "update": true,
                "delete": true
              }
            },
            {
              "parameter": "observation_date",
              "parameter_type": "date",
              "required": false,
              "default_value": 0,
              "hint": "The date of the observation, leave blank to set today as date",
              "schema_table": {
                "schema": "observation",
                "table": "observation",
                "write": true
              },
              "permission": {
                "update": false,
                "delete": false
              }
            },
            {
              "parameter": "timestamp",
              "parameter_type": "timestamp",
              "required": false,
              "default_value": "",
              "hint": "The timestamp of the observation, leave blank to set now (1/10 of second precision)",
              "schema_table": {
                "schema": "observation",
                "table": "observation",
                "write": true
              },
              "permission": {
                "update": true,
                "delete": false
              }
            }
          ]
        }
      ]
    },
    {
      "process": "add_process",
      "overwrite": false,
      "parameters": {
        "root_process": "manage_table_data",
        "process": "manage_beerkan_infiltration_interval",
        "min_user_stratum": 2,
        "title": "Manage beerkan infiltration interval observation",
        "label": "Insert, update or delete beerkan infiltration interval data."
      },
      "nodes": [
        {
          "parent": "process",
          "element": "parameters",
          "parameter": [
            {
              "parameter": "infiltration_beerkan_id",
              "parameter_type": "integer",
              "required": true,
              "default_value": "",
              "hint": "The id of the infiltration_beerkan",
              "schema_table": {
                "schema": "observation",
                "table": "infiltration_beerkan_time",
                "write": true
              },
              "permission": {
                "update": false,
                "delete": false
              }
            },
            {
              "parameter": "interval_nr",
              "parameter_type": "integer",
              "required": true,
              "default_value": 0,
              "hint": "The sequence number of the interval",
              "schema_table": {
                "schema": "observation",
                "table": "infiltration_beerkan_time",
                "write": true
              },
              "permission": {
                "update": true,
                "delete": false
              }
            },
            {
              "parameter": "duration",
              "parameter_type": "float",
              "required": false,
              "default_value": 0,
              "hint": "Duration time of interval",
              "schema_table": {
                "schema": "observation",
                "table": "infiltration_beerkan_time",
                "write": true
              },
              "permission": {
                "update": true,
                "delete": false
              }
            }
          ]
        }
      ]
    }
  ]
}
