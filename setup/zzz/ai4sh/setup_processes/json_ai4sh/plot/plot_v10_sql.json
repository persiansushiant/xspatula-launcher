            },
            {
              "parameter": "filter",
              "parameter_type": "text",
              "required": false,
              "default_value": "none",
              "hint": "Set path to the JSON file defining the filter. Available filter options: moving-average, gauss, savitszky-golay. To run the default settings of any of these filter set the parameter to the filter name"
            },
